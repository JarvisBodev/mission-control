# Google Calendar API
# Create service account at https://console.cloud.google.com/apis/credentials
GOOGLE_CALENDAR_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_CALENDAR_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
GOOGLE_CALENDAR_CALENDAR_ID=primary

# Google Sheets API (BINB data)
GOOGLE_SHEETS_SHEET_ID=your-google-sheet-id-here
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON_PATH=./service-account.json

# Clawdbot Gateway
CLAWDBOT_GATEWAY_URL=http://localhost:18789
CLAWDBOT_GATEWAY_TOKEN=your-gateway-token

# Google CLI (gog) - Used for Calendar/Sheets access
GOG_KEYRING_PASSWORD=your-gog-keyring-password

# GitHub API (Projects section)
GITHUB_TOKEN=ghp_...
GITHUB_REPO_OWNER=JarvisBdev
GITHUB_REPO_NAME=mission-control

# Next.js Public Variables
NEXT_PUBLIC_APP_NAME=Mission Control Dashboard
NEXT_PUBLIC_APP_VERSION=1.0.0

# Development
NODE_ENV=development